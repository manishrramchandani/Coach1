<?xml version="1.0" encoding="UTF-8"?>
<!-- CALLOUT: App metadata. Camera/photo usage strings are required because the
     Progress screen uploads progress photos (FR-6.2). No location/health perms
     are requested in MVP. -->
<plist version="1.0">
<dict>
    <key>CFBundleDisplayName</key>
    <string>CoachOS</string>
    <key>CFBundleShortVersionString</key>
    <string>1.0</string>
    <key>CFBundleVersion</key>
    <string>1</string>
    <key>UILaunchScreen</key>
    <dict/>
    <key>NSPhotoLibraryUsageDescription</key>
    <string>CoachOS uses your photos so you can add progress photos for your coach.</string>
    <key>NSCameraUsageDescription</key>
    <string>CoachOS uses your camera to capture progress photos.</string>
    <key>UISupportedInterfaceOrientations</key>
    <array><string>UIInterfaceOrientationPortrait</string></array>
</dict>
</plist>
